{
    "manifest_version": 3,
    "name": "ClipGrab Pro Downloader",
    "description": "Download videos from YouTube, TikTok, Instagram and more with one click.",
    "version": "1.0",
    "permissions": [
        "activeTab",
        "downloads",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icon128.png"
        }
    },
    "icons": {
        "128": "icon128.png"
    }
}